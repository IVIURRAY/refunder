# AWS Configuration
AWS_REGION=eu-west-1
# Leave blank to use IAM role (recommended for Lambda)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3
RAW_EMAILS_BUCKET=refundagent-raw-emails

# SES
INBOUND_EMAIL_DOMAIN=refundagent.com

# RDS / PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=refundagent
DB_USER=refundagent
DB_PASSWORD=changeme
DB_POOL_SIZE=5

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=eu-west-1

# App
APP_NAME=refundagent
LOG_LEVEL=INFO
ENVIRONMENT=development
